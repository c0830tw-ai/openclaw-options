# Shioaji 永豐 API 認證
# 取得方式: https://sinotrade.github.io/zh_TW/quickstart/account/
SHIOAJI_API_KEY=your_api_key_here
SHIOAJI_SECRET_KEY=your_secret_key_here

# Firebase RTDB
# 用你既有的 ball python app 同一個專案即可，只是路徑不同
FIREBASE_CRED=./firebase-key.json
FIREBASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app
